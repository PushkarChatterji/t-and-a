MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/YOUR_DB_NAME?retryWrites=true&w=majority
JWT_SECRET=replace-with-64-char-random-string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
BCRYPT_ROUNDS=12

SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=your-ethereal-user
SMTP_PASS=your-ethereal-pass
EMAIL_FROM=noreply@eduportal.com

NEXT_PUBLIC_APP_URL=http://localhost:3000
AUTO_LOGOFF_MINUTES=120
ADAPTIVE_THRESHOLD=5
